<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="restinfo">
    <insert id="signUp" parameterType="Map">
        insert into User (ID, Pwd, Authority,Name, platform, cancel)
        values (#{ID}, #{Pwd}, 0,#{Name},#{platform}, 0)

    </insert>
    <select id="selectID" resultType="mybatis.vo.UserVO" parameterType="Map">
        select * from User where ID     
    </select>

</mapper>