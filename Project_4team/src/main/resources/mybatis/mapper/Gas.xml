<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="GAS">
    <select id="getGas" parameterType="String" resultType="mybatis.vo.gasVO">
        select * from Gas
        WHERE SAKey = #{idx}
    </select>

</mapper>