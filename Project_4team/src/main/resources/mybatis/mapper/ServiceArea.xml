<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="restinfo">
    <select id="all" resultType="mybatis.vo.ServiceAreaVO">
        select * from ServiceArea
    </select>
    <update id="xY" parameterType="Map">
        update ServiceArea SET
        lat = #{lat},
        lng = #{lng}
        WHERE
        Idx = #{idx}
    </update>

</mapper>