<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="restinfo">
    <select id="login" parameterType="String" resultType="mybatis.vo.UserVO">
        select * from User
        WHERE ID = #{ID} 
    </select>

</mapper>